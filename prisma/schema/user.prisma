model User {
  id       String   @id @default(cuid())
  email    String
  username String
  password String
  userType UserType @default(OWNER)
  avatar   String?

  // Auth fields
  googleId String? @unique

  /// [MfaSettingsType]
  mfaSettings Json?

  /// [OtpSettingsType]
  otp Json?

  /// [PasswordResetSettingsType]
  passwordReset Json?

  // Shard tracking — critical for routing after login
  shardId String?

  // Multi-user: sub-users belong to an OWNER
  ownerId  String?
  owner    User?  @relation("OwnerSubUsers", fields: [ownerId], references: [id], onDelete: Cascade)
  subUsers User[] @relation("OwnerSubUsers")

  // Roles owned by this OWNER
  ownedRoles Role[] @relation("OwnedRoles")

  // RBAC: roles assigned to this user
  roles             Role[]     @relation("UserRoles")
  customPermissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, ownerId, userType])
  @@index([email])
  @@index([userType])
  @@index([ownerId])
}
