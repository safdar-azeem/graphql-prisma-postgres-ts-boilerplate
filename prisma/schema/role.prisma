model Role {
  id          String       @id @default(cuid())
  name        String
  ownerId     String
  owner       User         @relation("OwnedRoles", fields: [ownerId], references: [id], onDelete: Cascade)
  permissions Permission[]

  users User[] @relation("UserRoles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, ownerId])
  @@index([ownerId])
}
